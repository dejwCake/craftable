{
    "name": "dejwcake/craftable",
    "description": "Administration toolkit for Laravel - starting point for developing administration interface",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "craftable",
        "crud",
        "brackets",
        "admin",
        "administration",
        "toolkit",
        "framework",
        "cms",
        "laravel"
    ],
    "authors": [
        {
            "name": "David Běhal",
            "email": "david.behal@dejw.sk",
            "homepage": "https://www.dejw.sk",
            "role": "Developer"
        },
        {
            "name": "Pavol Perdík",
            "email": "pavol.perdik@brackets.sk",
            "homepage": "https://www.brackets.sk",
            "role": "Developer"
        },
        {
            "name": "Richard Dominik",
            "email": "richard.dominik@brackets.sk",
            "homepage": "https://www.brackets.sk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "dejwcake/admin-auth": "^2.0",
        "dejwcake/admin-listing": "^2.0",
        "dejwcake/admin-translations": "^2.0",
        "dejwcake/admin-ui": "^2.0",
        "dejwcake/advanced-logger": "^2.0",
        "dejwcake/craftable-media": "^2.0",
        "dejwcake/craftable-translatable": "^2.0",
        "illuminate/support": "^13.0",
        "maatwebsite/excel": "^3.1",
        "spatie/laravel-backup": "^10.2",
        "spatie/laravel-permission": "^7.2"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^13.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Brackets\\Craftable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Brackets\\Craftable\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.0-dev",
            "dev-v2-dev": "2.0-dev"
        },
        "laravel": {
            "providers": [
                "Brackets\\Craftable\\CraftableServiceProvider"
            ]
        }
    }
}
